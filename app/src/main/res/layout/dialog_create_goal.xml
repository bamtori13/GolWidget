<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_dialog_goal_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="새 목표 만들기"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <!-- 목표 이름 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="목표 이름 *"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_goal_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="예: 월간 매출, 독서 목표, 운동..."
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:inputType="text"
            android:layout_marginBottom="14dp" />

        <!-- 단위 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="단위 (선택)"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_goal_unit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="예: 만원, 권, km, 회..."
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <!-- 구분선 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/divider" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="목표값 설정"
                android:textSize="12sp"
                android:textColor="@color/text_hint" />
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/divider" />
        </LinearLayout>

        <!-- 총 목표값 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="총 목표값 *"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="3dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="세부 항목을 추가하면 항목 합계로 자동 계산됩니다"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_goal_target"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="예: 100, 500000..."
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:inputType="numberDecimal"
            android:layout_marginBottom="14dp" />

        <!-- 현재 달성값 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="현재 달성값 (선택, 기본 0)"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_goal_current"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="0"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp" />

        <!-- 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_goal_cancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="취소"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/input_background"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_goal_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="만들기"
                android:textSize="15sp"
                android:textColor="@color/surface"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
