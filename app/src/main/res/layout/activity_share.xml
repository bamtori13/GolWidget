<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 현재 상태 카드 -->
        <LinearLayout
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="공유 상태"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/v_status_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/fab_background"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="공유 비활성"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- 그룹 코드 표시 (공유 중일 때) -->
            <LinearLayout
                android:id="@+id/layout_group_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="초대 코드"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_group_code"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="------"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:letterSpacing="0.3" />

                    <TextView
                        android:id="@+id/btn_copy_code"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="복사"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/goal_card_bg"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가족에게 이 코드를 알려주세요. 코드로 같은 그룹에 참여할 수 있습니다."
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- 탈퇴 버튼 (공유 중일 때) -->
            <TextView
                android:id="@+id/btn_leave"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="공유 그룹 나가기"
                android:textSize="14sp"
                android:textColor="@color/danger"
                android:background="@drawable/input_background"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 닉네임 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 닉네임"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/et_nickname"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:hint="이름을 입력하세요"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:inputType="text"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/btn_save_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="저장"
                    android:textSize="14sp"
                    android:textColor="@color/surface"
                    android:background="@drawable/btn_primary"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- 새 그룹 만들기 카드 (비활성 상태일 때) -->
        <LinearLayout
            android:id="@+id/card_create"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="새 공유 그룹 만들기"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 목표 목록을 공유 그룹에 올리고\n가족에게 초대 코드를 전달합니다."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/btn_create_group"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="그룹 만들기"
                android:textSize="15sp"
                android:textColor="@color/surface"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 그룹 참여 카드 (비활성 상태일 때) -->
        <LinearLayout
            android:id="@+id/card_join"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="초대 코드로 참여"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가족에게 받은 6자리 초대 코드를 입력하세요."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="14dp" />

            <EditText
                android:id="@+id/et_invite_code"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="예: AB3X7K"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:inputType="textCapCharacters"
                android:maxLength="6"
                android:letterSpacing="0.3"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/btn_join_group"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="참여하기"
                android:textSize="15sp"
                android:textColor="@color/surface"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 안내 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️  주의사항\n• 같은 그룹에서는 모든 목표가 실시간으로 공유됩니다\n• 그룹을 나가면 공유가 중단되지만 데이터는 유지됩니다\n• Firebase 서버를 이용하므로 인터넷 연결이 필요합니다"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:padding="12dp"
            android:background="@drawable/input_background"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</ScrollView>
